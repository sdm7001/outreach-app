# ============================================================
# Outreach Enterprise Platform — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to source control.

# ------------------------------------------------------------
# REQUIRED — app will not start without these
# ------------------------------------------------------------

# JWT secret — use at least 32 random characters
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_random_32_char_string

# Admin account password (first-run setup creates admin@example.com with this password)
ADMIN_PASSWORD=ChangeMe1!

# ------------------------------------------------------------
# App Settings
# ------------------------------------------------------------
PORT=3848
NODE_ENV=development

# 'manual' = all AI drafts require human review before sending
# 'auto'   = drafts are auto-approved and queued immediately
REVIEW_MODE=manual

# Path to SQLite database file
DB_PATH=./data/outreach.db

# CORS allowed origin (* = all)
CORS_ORIGIN=*

# JWT expiry in hours
JWT_EXPIRY_HOURS=8

# bcrypt rounds (higher = slower but more secure; 12 is a good default)
BCRYPT_ROUNDS=12

# Login rate limit (attempts per minute per IP)
MAX_LOGIN_ATTEMPTS_PER_MIN=10

# ------------------------------------------------------------
# AI Message Generation (optional — gracefully disabled if unset)
# ------------------------------------------------------------

# Anthropic API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Claude model to use for email generation
AI_MODEL=claude-haiku-4-5

# Max tokens for generated messages
AI_MAX_TOKENS=600

# Prompt version tag (used for audit/tracking)
AI_PROMPT_VERSION=v1

# ------------------------------------------------------------
# Prospect Sourcing (optional — features disabled if unset)
# ------------------------------------------------------------

# Apollo.io API key — for company/contact discovery
APOLLO_API_KEY=

# Google Places API key — for local business discovery
GOOGLE_PLACES_API_KEY=

# Hunter.io API key — for email enrichment
HUNTER_API_KEY=

# ------------------------------------------------------------
# Email Sending (optional — logs emails to console if unset)
# ------------------------------------------------------------

# SMTP server settings (defaults to Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Gmail address (or other SMTP username)
SMTP_USER=

# Gmail App Password (NOT your account password)
# Setup: https://support.google.com/accounts/answer/185833
SMTP_PASS=

# Sender display name and email
FROM_NAME=Lindsay Thompson
FROM_EMAIL=

# Domain used for open/click tracking links (must be publicly accessible in production)
TRACKING_DOMAIN=http://localhost:3848

# ------------------------------------------------------------
# Sending Safety Controls
# ------------------------------------------------------------

# Max prospects to find per day (across all campaigns)
DAILY_PROSPECT_LIMIT=10

# Max emails to send per day
EMAILS_PER_DAY=10

# Stagger delay between emails: min and max in milliseconds
# Default: 8–12 minutes (reduces spam signals)
EMAIL_STAGGER_MIN_MS=480000
EMAIL_STAGGER_MAX_MS=720000

# Business hours window for sending (24h format, server timezone)
SEND_WINDOW_START=8
SEND_WINDOW_END=17

# Whether to send to email addresses that were guessed (not verified)
# Strongly recommended: false
SEND_GUESSED_EMAILS=false

# ------------------------------------------------------------
# Telegram Notifications (optional)
# ------------------------------------------------------------

# Telegram bot token — from @BotFather
TG_BOT_TOKEN=

# Telegram chat ID to send reports to
TG_CHAT_ID=

# ------------------------------------------------------------
# Company Identity (used in emails and unsubscribe footers)
# ------------------------------------------------------------

COMPANY_NAME=TexMG
COMPANY_ADDRESS=21175 Tomball Parkway, Houston TX 77070
COMPANY_WEBSITE=https://texmg.com
TALOS_WEBSITE=https://talosautomation.ai

# Admin user email (used by setup.js to create the initial admin account)
ADMIN_EMAIL=admin@example.com
